{
  "name": "node-aws-terraform-boilerplate",
  "version": "0.2.0",
  "author": "Viktor Jancik",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "helm:lint": "helm lint helm/*",
    "tf:validate": "terraform -chdir=terraform/shared validate && terraform -chdir=terraform/database validate && terraform -chdir=terraform/bastion validate && terraform -chdir=terraform/ecs validate && terraform -chdir=terraform/eks validate",
    "compose:up": "docker compose -f docker-compose.local.yaml up --build -d --wait",
    "compose:down": "docker compose -f docker-compose.local.yaml down",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "lefthook": "^2.1.6",
    "turbo": "^2.9.6",
    "ultracite": "7.6.0"
  }
}
